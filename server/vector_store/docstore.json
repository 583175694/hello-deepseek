[[["9a08814f-89fb-4ef1-8948-88244f00ca60",{"pageContent":"Initial document to initialize vector store","metadata":{"source":"initialization"}}],["06980547-9f13-43f6-ba28-920b48f85e06",{"pageContent":"\u0000 工作经历\n我的简历\n28岁，前端开发，6年经验\n擅⻓WEB • H5 • APP • 小程序 • 客户端的开发\n逻辑思维能力与同理心强，擅⻓人与人之间沟通协作\n15876092583\n\nw583175694\n\n583175694@qq.com\n✉\n2024\n2022.8-至今\n2022\n2021.11-2022.7\n微众 - 大前端工程师\n担任前端工程师，负责微众银行企业金融APP的开发\n负责部⻔内部AI大模型应用的开发\n腾讯 - 大前端工程师\n担任前端工程师，负责拳头游戏 Valorant 登录器 Electron 客户端的开发\n掌上英雄联盟电竞经理手游社区项目 React Native 的开发\n2020\n2020.7-2021.11\n深圳市果酱时代科技有限公司 - 前端工程师\n担任前端工程师，负责直播平台的功能迭代、礼物动效性能优化、历史遗留问题\n的修复\n2018\n2018.8-2020.7\n深圳创感科技有限公司 - 大前端工程师\n 担任大前端工程师，负责网⻚、H5、小程序、Flutter APP开发\n我的简历 - 1","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":1,"lines":{"from":1,"to":31}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["515388a0-587c-4262-8a12-96432361a292",{"pageContent":"\u0000 技能特⻓\n擅⻓ \nHTML\n，\nCSS3\n，\nW3C\n 标准和语义化标签，熟练实现各种动效，布局   \n擅⻓ \nES5\n，\nES6\n，\nTypeScript\n \n擅⻓ \nReact\n、\nReact Hooks\n及其全家桶，\nRedux\n 状态机\n擅⻓ \nVue2\n、\nVue3\n 及其全家桶  \n擅⻓ \nReact Native\n、\nFlutter\n 跨端开发，能够独立完成 \niOS\n，\nAndroid\n 的开发  \n擅⻓\nLangchain\n、\nprompt turning\n等AI应用开发基础\n熟悉 \nElectron\n 客户端的跨端开发，以及\nvscode\n插件开发\n熟悉 \nNodeJS\n，能够使用 \nNestJS\n 完成数据中台的开发\n熟悉 \nHTTP\n/\nHTTPS\n/\nQUIC\n 等网络协议基本原理\n熟练使用 \ngit\n 代码管理工具，会用 \ngit\n 可视化工具解决代码冲突\n\u0000 项目经历\n2024\n2022.8-至今\n微众银行 - 微众银行企业金融APP - \nReact  Native\n开发 - \nVue3\n开\n发\n⭐ 项目介绍：微众银行是领先的数字银行，专注为中小微企业和普罗大众提供更为\n优质、便捷的金融服务。包含贷款、贴现、保险、理财、账户、微创投\n⭐ 技术栈：\n业务层：React Native，React Hook，Vue3，Vite，TypeScript；\n能力层：Android Native，iOS Native，跨端能力建设，SDK建设，监控建\n设；\n应用安全层：国密SSL SM4、SM2，交易密码验证，FIDO生物识别，人脸认\n证、在线视频等。\n⭐ 主要职能：\n业务发展与客户服务：负责企业开户、企业信息变更、保险产品、存款服务、\n专利AI、微创投资、聚合支付和薪资发放等关键业务的开发与流程优化，以及\n支付安全相关的设计。\n安全体系建设：设计并实施了全面的登录安全体系，包括报文加密、手机号绑\n定、手势密码、面部识别、指纹识别、一次性密码（OTP）、面部认证和在线视\n频验证等多重安全措施，以增强账户安全性和用户信任。\n1.\n2.\n3.\n1.\n2.\n技术项目管理：3.\n我的简历 - 2","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":2,"lines":{"from":1,"to":94}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["0d31335c-6cf6-4449-8dd5-8241a7c98c14",{"pageContent":"负责H5项目工程化建设，采用pnpm monorepo架构，成功整合和改造了\n包括理财、保险、票据等在内的十多个H5应用。管理项目依赖，优化公共\n代码库，实施持续集成/持续部署（CI/CD）流程，确保版本控制和软件发\n布流程的高效与稳定。\n参与企业金融APP跨端能力建设，设计并实现基于JS-SDK架构的跨端解\n决方案，提供包括用户信息获取、支付、生物识别等30+原生能力调用。\n构建了基于appId+appSecret的鉴权机制和code置换登录态的双重认证\n体系，实现H5与Native间安全可信通信。通过Webview拦截器结合\nMD5+盐值校验的离线包加载方案使首屏加载提速50%，并基于域名白名\n单+jsTicket的动态校验确保接口调用安全。完善SDK文档和标准化建\n设，简化业务方接入流程，目前已接入数十个业务。\na.\nb.\n2024\n2023.9-至今\n微众银行 - AI大模型应用体系建设\n⭐ 项目介绍：在当前的行业趋势下，我们致力于通过采用先进的人工智能技术，以\n创新的方式实现成本优化和效率提升。目前的产品有VSCode编辑器AI插件，前\n端RAG与知识库平台，管理台代码生成平台。\n⭐ 技术栈：Langchain，codellama，deepseek，RAG，Chroma，Prompt \ntune，VSCode SDK，NestJS\n⭐ 主要职能：\nAI大模型应用体系建设负责人：负责部⻔内人工智能大模型的应用体系构建，\n推动AI技术在业务流程中的深度融合与创新应用。\nVSCode AI插件开发：开发VSCode编辑器AI插件，整合Codellama 34B和\nDeepSeek 7B模型，实现代码生成、智能补全、代码翻译、智能问答等功能。\n插件已实现代码补全采纳20,000+次，采纳率达12%，智能问答3,000+次，\n显著提升团队编码效率近30%。\n前端RAG与知识库平台建设：运用Langchain、Embedding模型和向量数据\n库技术，结合本地部署的ChatGLM3模型，构建前端团队知识库平台，优化团\n队资料检索流程。\n管理台代码生成平台开发：利用Codellama 34B模型和prompt tuning技术，\n开发基于自然语言的Vue2 + CompositionAPI + ElementUI管理台代码生成平","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":3,"lines":{"from":1,"to":33}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["26c7eaa1-8e87-498a-b2eb-ee420a187994",{"pageContent":"前端RAG与知识库平台建设：运用Langchain、Embedding模型和向量数据\n库技术，结合本地部署的ChatGLM3模型，构建前端团队知识库平台，优化团\n队资料检索流程。\n管理台代码生成平台开发：利用Codellama 34B模型和prompt tuning技术，\n开发基于自然语言的Vue2 + CompositionAPI + ElementUI管理台代码生成平\n台。集成vue-live实现代码实时预览功能，进一步提升开发效率和用户体验。\n1.\n2.\n3.\n4.\n2022\n2021.11-2022.8\n腾讯IEG - Valorant 客户端 - Electron开发\n⭐ 项目介绍：拳头游戏 Valorant 在国外已经上线且有不错的关注度，Valorant 计\n划在 2022 年下半年引入国内，因此需要做一个游戏的启动器，功能点包括游戏的\n登录、游戏更新、启动器的更新、游戏与启动器数据的共享、用户登录态的校验等\n等\n⭐ 技术栈：客户端采用 Electron 跨端技术实现客户端底层能力，前端使用 Vue3 \n+ Vite + tailwindcss 作为基础业务的搭建，中台基于 node + nestjs + serverless \n对接多项第三方业务平台，提供拳头公司游戏统一协调服务\n我的简历 - 3","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":3,"lines":{"from":29,"to":49}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["f32c1255-3086-4846-a734-1b9c24a1dc96",{"pageContent":"⭐ 主要收获：\n掌握 Electron 客户端的研发，以及主进程、渲染进程之间的IPC通信协议，基\n于 node 对 window 客户端底层能力的协调处理\n参与中台的基础架构以及技术选型，基于 node 对第三方服务进行统一规范，以\n及提供拳头公司服务对接\n参与制定拳头公司的对接安全规范，实现业务方与平台方的信息安全交互\n1.\n2.\n3.\n2021\n2021.11-2022.8\n腾讯IEG - 掌上英雄联盟APP电竞经理社区 - React Native开发\n⭐ 项目介绍：腾讯计划在 2022 年年中上线“电竞经理手游”，掌上英雄联盟作为\n拳头游戏的社区平台，将新增“电竞经理”社区模块。功能点包括游戏的资讯，阵容\n的推荐、用户个人资料显示、战绩查询等等\n⭐ 技术栈：采用移动端跨平台方案 React Native + React Hooks + fower 作为应\n用的框架，使用 react-native-echarts-pro 作为图表功能的处理，采用 React \nNative 原生动画对用户体验的优化\n⭐ 主要收获：\n掌握 React Native 的研发及其实现原理，提供多端适配的解决方案\n掌握 React Hooks API 的使用，对通用组件进行统一抽象处理\n独立调研并最终推广实现 fower 技术解决方案， 解决 react native 样式体积\n大、复杂度高的问题，极大提高了前端项目组的开发效率\n参与掌上英雄联盟团队的开发协作\n1.\n2.\n3.\n4.\n2020\n2020.7-2021.11\n星光直播平台 - Web/小程序开发\n⭐ 项目介绍：\n星光直播是一个综合性视频社交平台,包含直播和短视频两大核心功能。我主要负责:\n基于 Taro + TypeScript 开发短视频模块,实现类抖音的视频浏览体验\n使用原生 JavaScript + PHP 开发直播模块,通过 Bodymovin 实现礼物动效渲染\n⭐ 技术难点与解决方案：\n1.\n2.\n短视频模块性能优化1.\n使用 Redux 管理状态，避免滑动切换时的卡顿\n优化视频切换和评论抽屉等动画，使性能监控保持在 60 帧\n双层 Swiper 嵌套方案实现流畅的视频切换效果\n直播模块动效优化2.\n优化礼物动效和宝箱掉落动画的渲染性能\n在高并发送礼场景下保持流畅的动画效果","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":4,"lines":{"from":1,"to":45}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["c817d4a2-f31c-41ee-8120-c3064d145a37",{"pageContent":"⭐ 技术难点与解决方案：\n1.\n2.\n短视频模块性能优化1.\n使用 Redux 管理状态，避免滑动切换时的卡顿\n优化视频切换和评论抽屉等动画，使性能监控保持在 60 帧\n双层 Swiper 嵌套方案实现流畅的视频切换效果\n直播模块动效优化2.\n优化礼物动效和宝箱掉落动画的渲染性能\n在高并发送礼场景下保持流畅的动画效果\n性能监控显示优化后全程保持最佳帧率\n我的简历 - 4","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":4,"lines":{"from":36,"to":47}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["790235b3-329d-4a8b-85f2-1f771e9fbfca",{"pageContent":"\u0000 教育\n⭐ 技术成果：\n封装接口回调数据类型定义，提供完善的 TypeScript 类型提示\n模块化重构重复代码，提升可维护性\n修复 XSS 安全隐患，完善网络层架构\n建立统一的性能监控标准，实现动画性能从 40fps 提升到稳定 60fps\n1.\n2.\n3.\n4.\n2019\n2019.12-\n2020.3\n体态专家IPad、Andriod Pad - flutter开发\n⭐ 项目介绍：体态专家是一套基于人工智能的体态评估系统。该体态评估系统无需\n手动瞄点划线，通过机器视觉技术自动识别身体关键点，模拟人体⻣骼机构并分析\n肌肉的状态，无需拍摄X光片就可以快速预测身体健康的十余项⻛险，最终给出体\n态评分与建议。\n⭐ 技术栈：使用了近期比较火的移动端跨平台方案——flutter，状态管理使用了官\n方推荐的 scope_model。难点在于体态的描点系统，将后端的关键点渲染完毕后，\n前端可进行微调。点击激活关键点保持 canvas 中心，缩放以及移动背景图，再次\n点击确定关键点移动后的位置，类似地图 app 的定位。\n⭐ 主要收获：最满意的app项目，对canvas处理有了比较大的突破，在测试以及\n产品经理的帮助下，将产品一步步的完善，细节处理的也比较到位，对flutter的技\n术栈有了进一步的突破\n2018\n2018.11-2019.5\n体态检测小程序 - React 小程序开发 \n⭐ 项目介绍：公司的核心产品，曾被 keep 抄袭。通过拍摄正面以及侧面两张照片\n即可检测出你的各项体态指标，例如高低肩，头前倾等。\n⭐ 技术栈：使用了 Taro 框架，状态管理使用 Redux，语言使用 TypeScript。由\n于后端使用 grpc 框架，可生成前端可使用的 class 类的 ts 文件，前端发起请求时\n继承此 class 类，遵循接口定义的属性类型，减少了前后端沟通成本以及错误率。\n难点在于体态报告的数据展示，数据结构的处理，包括了姿态融合算法以及⻆度的\n计算，canvas 点，线的绘画等。\n⭐ 主要收获：\n对业务逻辑的强化锻炼，对模块进行的封装，面向对象的编程思想\n对状态管理中状态树的构建等吗强化对 canvas 的各项操作\n首次接触了算法，虽说大部分是借鉴。对复杂的数据的处理，对冗杂的代码进\n行模块化的剖析等。\n1.\n2.\n3.","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":5,"lines":{"from":1,"to":43}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["9299bd2f-c94d-4375-ad0f-b165fdebc943",{"pageContent":"难点在于体态报告的数据展示，数据结构的处理，包括了姿态融合算法以及⻆度的\n计算，canvas 点，线的绘画等。\n⭐ 主要收获：\n对业务逻辑的强化锻炼，对模块进行的封装，面向对象的编程思想\n对状态管理中状态树的构建等吗强化对 canvas 的各项操作\n首次接触了算法，虽说大部分是借鉴。对复杂的数据的处理，对冗杂的代码进\n行模块化的剖析等。\n1.\n2.\n3.\n2014-2018电子科技大学中山学院\n通信工程\n我的简历 - 5","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":5,"lines":{"from":34,"to":46}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["480e8f3f-654f-490b-a58d-92f5b22d6cb9",{"pageContent":"\u0000 个人\n校学生会\n2014—2016学年参加了电子科技大学中山学院校学生会，担任学术部部员 \n河源学子联谊会\n2016—2017学年参加了电子科技大学中山学院河源学子联谊会，担任会⻓ \n孟老师项目组\n2016—2018参加了电子科技大学中山学院孟庆元老师项目组，担任成员，后期担\n任班⻓\n自学能力\n从大二末开始自学前端，加入学院老师项目组做一些全栈项目，毕业后技术栈⻜速成\n⻓，目前能独自承包网站，h5，各类小程序，Andriod app及IOS app的开发。\n工作热情\n喜欢编程，工作踏实，在自己喜欢的氛围下不觉得工作是件应该抱怨的事；态度认真，\n在沟通中有分歧时从来都是选择最优解，不会为了避免增加工作量而选择凑合，融洽的\n团队配合。\n学习热情\n喜欢探索新事物、新技术，喜欢挑战，有好奇心。每年对自己有特定的目标及要求。\n责任心\n对待自己的作品就像自己的孩子一样，认真、细节，注重用户体验\n我的简历 - 6","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739436829850.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":6,"lines":{"from":1,"to":20}},"filename":"吴少航的简历_1739436829850.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-13T08:53:50.066Z","mimeType":"application/pdf"}}],["035557bf-4256-4097-83ba-5090846acdb0",{"pageContent":"\u0000 工作经历\n我的简历\n28岁，前端开发，6年经验\n擅⻓WEB • H5 • APP • 小程序 • 客户端的开发\n逻辑思维能力与同理心强，擅⻓人与人之间沟通协作\n15876092583\n\nw583175694\n\n583175694@qq.com\n✉\n2024\n2022.8-至今\n2022\n2021.11-2022.7\n微众 - 大前端工程师\n担任前端工程师，负责微众银行企业金融APP的开发\n负责部⻔内部AI大模型应用的开发\n腾讯 - 大前端工程师\n担任前端工程师，负责拳头游戏 Valorant 登录器 Electron 客户端的开发\n掌上英雄联盟电竞经理手游社区项目 React Native 的开发\n2020\n2020.7-2021.11\n深圳市果酱时代科技有限公司 - 前端工程师\n担任前端工程师，负责直播平台的功能迭代、礼物动效性能优化、历史遗留问题\n的修复\n2018\n2018.8-2020.7\n深圳创感科技有限公司 - 大前端工程师\n 担任大前端工程师，负责网⻚、H5、小程序、Flutter APP开发\n我的简历 - 1","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":1,"lines":{"from":1,"to":31}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["6ce444cb-d5f7-4f18-8870-35f0c0f3fbec",{"pageContent":"\u0000 技能特⻓\n擅⻓ \nHTML\n，\nCSS3\n，\nW3C\n 标准和语义化标签，熟练实现各种动效，布局   \n擅⻓ \nES5\n，\nES6\n，\nTypeScript\n \n擅⻓ \nReact\n、\nReact Hooks\n及其全家桶，\nRedux\n 状态机\n擅⻓ \nVue2\n、\nVue3\n 及其全家桶  \n擅⻓ \nReact Native\n、\nFlutter\n 跨端开发，能够独立完成 \niOS\n，\nAndroid\n 的开发  \n擅⻓\nLangchain\n、\nprompt turning\n等AI应用开发基础\n熟悉 \nElectron\n 客户端的跨端开发，以及\nvscode\n插件开发\n熟悉 \nNodeJS\n，能够使用 \nNestJS\n 完成数据中台的开发\n熟悉 \nHTTP\n/\nHTTPS\n/\nQUIC\n 等网络协议基本原理\n熟练使用 \ngit\n 代码管理工具，会用 \ngit\n 可视化工具解决代码冲突\n\u0000 项目经历\n2024\n2022.8-至今\n微众银行 - 微众银行企业金融APP - \nReact  Native\n开发 - \nVue3\n开\n发\n⭐ 项目介绍：微众银行是领先的数字银行，专注为中小微企业和普罗大众提供更为\n优质、便捷的金融服务。包含贷款、贴现、保险、理财、账户、微创投\n⭐ 技术栈：\n业务层：React Native，React Hook，Vue3，Vite，TypeScript；\n能力层：Android Native，iOS Native，跨端能力建设，SDK建设，监控建\n设；\n应用安全层：国密SSL SM4、SM2，交易密码验证，FIDO生物识别，人脸认\n证、在线视频等。\n⭐ 主要职能：\n业务发展与客户服务：负责企业开户、企业信息变更、保险产品、存款服务、\n专利AI、微创投资、聚合支付和薪资发放等关键业务的开发与流程优化，以及\n支付安全相关的设计。\n安全体系建设：设计并实施了全面的登录安全体系，包括报文加密、手机号绑\n定、手势密码、面部识别、指纹识别、一次性密码（OTP）、面部认证和在线视\n频验证等多重安全措施，以增强账户安全性和用户信任。\n1.\n2.\n3.\n1.\n2.\n技术项目管理：3.\n我的简历 - 2","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":2,"lines":{"from":1,"to":94}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["f73a964f-4406-455a-8b68-edaf3b18937d",{"pageContent":"负责H5项目工程化建设，采用pnpm monorepo架构，成功整合和改造了\n包括理财、保险、票据等在内的十多个H5应用。管理项目依赖，优化公共\n代码库，实施持续集成/持续部署（CI/CD）流程，确保版本控制和软件发\n布流程的高效与稳定。\n参与企业金融APP跨端能力建设，设计并实现基于JS-SDK架构的跨端解\n决方案，提供包括用户信息获取、支付、生物识别等30+原生能力调用。\n构建了基于appId+appSecret的鉴权机制和code置换登录态的双重认证\n体系，实现H5与Native间安全可信通信。通过Webview拦截器结合\nMD5+盐值校验的离线包加载方案使首屏加载提速50%，并基于域名白名\n单+jsTicket的动态校验确保接口调用安全。完善SDK文档和标准化建\n设，简化业务方接入流程，目前已接入数十个业务。\na.\nb.\n2024\n2023.9-至今\n微众银行 - AI大模型应用体系建设\n⭐ 项目介绍：在当前的行业趋势下，我们致力于通过采用先进的人工智能技术，以\n创新的方式实现成本优化和效率提升。目前的产品有VSCode编辑器AI插件，前\n端RAG与知识库平台，管理台代码生成平台。\n⭐ 技术栈：Langchain，codellama，deepseek，RAG，Chroma，Prompt \ntune，VSCode SDK，NestJS\n⭐ 主要职能：\nAI大模型应用体系建设负责人：负责部⻔内人工智能大模型的应用体系构建，\n推动AI技术在业务流程中的深度融合与创新应用。\nVSCode AI插件开发：开发VSCode编辑器AI插件，整合Codellama 34B和\nDeepSeek 7B模型，实现代码生成、智能补全、代码翻译、智能问答等功能。\n插件已实现代码补全采纳20,000+次，采纳率达12%，智能问答3,000+次，\n显著提升团队编码效率近30%。\n前端RAG与知识库平台建设：运用Langchain、Embedding模型和向量数据\n库技术，结合本地部署的ChatGLM3模型，构建前端团队知识库平台，优化团\n队资料检索流程。\n管理台代码生成平台开发：利用Codellama 34B模型和prompt tuning技术，\n开发基于自然语言的Vue2 + CompositionAPI + ElementUI管理台代码生成平","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":3,"lines":{"from":1,"to":33}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["4b72588c-be47-42fd-b947-e51cda4782cf",{"pageContent":"前端RAG与知识库平台建设：运用Langchain、Embedding模型和向量数据\n库技术，结合本地部署的ChatGLM3模型，构建前端团队知识库平台，优化团\n队资料检索流程。\n管理台代码生成平台开发：利用Codellama 34B模型和prompt tuning技术，\n开发基于自然语言的Vue2 + CompositionAPI + ElementUI管理台代码生成平\n台。集成vue-live实现代码实时预览功能，进一步提升开发效率和用户体验。\n1.\n2.\n3.\n4.\n2022\n2021.11-2022.8\n腾讯IEG - Valorant 客户端 - Electron开发\n⭐ 项目介绍：拳头游戏 Valorant 在国外已经上线且有不错的关注度，Valorant 计\n划在 2022 年下半年引入国内，因此需要做一个游戏的启动器，功能点包括游戏的\n登录、游戏更新、启动器的更新、游戏与启动器数据的共享、用户登录态的校验等\n等\n⭐ 技术栈：客户端采用 Electron 跨端技术实现客户端底层能力，前端使用 Vue3 \n+ Vite + tailwindcss 作为基础业务的搭建，中台基于 node + nestjs + serverless \n对接多项第三方业务平台，提供拳头公司游戏统一协调服务\n我的简历 - 3","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":3,"lines":{"from":29,"to":49}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["00a62f56-f497-4eda-bbc2-489d3edebe43",{"pageContent":"⭐ 主要收获：\n掌握 Electron 客户端的研发，以及主进程、渲染进程之间的IPC通信协议，基\n于 node 对 window 客户端底层能力的协调处理\n参与中台的基础架构以及技术选型，基于 node 对第三方服务进行统一规范，以\n及提供拳头公司服务对接\n参与制定拳头公司的对接安全规范，实现业务方与平台方的信息安全交互\n1.\n2.\n3.\n2021\n2021.11-2022.8\n腾讯IEG - 掌上英雄联盟APP电竞经理社区 - React Native开发\n⭐ 项目介绍：腾讯计划在 2022 年年中上线“电竞经理手游”，掌上英雄联盟作为\n拳头游戏的社区平台，将新增“电竞经理”社区模块。功能点包括游戏的资讯，阵容\n的推荐、用户个人资料显示、战绩查询等等\n⭐ 技术栈：采用移动端跨平台方案 React Native + React Hooks + fower 作为应\n用的框架，使用 react-native-echarts-pro 作为图表功能的处理，采用 React \nNative 原生动画对用户体验的优化\n⭐ 主要收获：\n掌握 React Native 的研发及其实现原理，提供多端适配的解决方案\n掌握 React Hooks API 的使用，对通用组件进行统一抽象处理\n独立调研并最终推广实现 fower 技术解决方案， 解决 react native 样式体积\n大、复杂度高的问题，极大提高了前端项目组的开发效率\n参与掌上英雄联盟团队的开发协作\n1.\n2.\n3.\n4.\n2020\n2020.7-2021.11\n星光直播平台 - Web/小程序开发\n⭐ 项目介绍：\n星光直播是一个综合性视频社交平台,包含直播和短视频两大核心功能。我主要负责:\n基于 Taro + TypeScript 开发短视频模块,实现类抖音的视频浏览体验\n使用原生 JavaScript + PHP 开发直播模块,通过 Bodymovin 实现礼物动效渲染\n⭐ 技术难点与解决方案：\n1.\n2.\n短视频模块性能优化1.\n使用 Redux 管理状态，避免滑动切换时的卡顿\n优化视频切换和评论抽屉等动画，使性能监控保持在 60 帧\n双层 Swiper 嵌套方案实现流畅的视频切换效果\n直播模块动效优化2.\n优化礼物动效和宝箱掉落动画的渲染性能\n在高并发送礼场景下保持流畅的动画效果","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":4,"lines":{"from":1,"to":45}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["9f323826-c55e-447e-8c5e-63138db53a60",{"pageContent":"⭐ 技术难点与解决方案：\n1.\n2.\n短视频模块性能优化1.\n使用 Redux 管理状态，避免滑动切换时的卡顿\n优化视频切换和评论抽屉等动画，使性能监控保持在 60 帧\n双层 Swiper 嵌套方案实现流畅的视频切换效果\n直播模块动效优化2.\n优化礼物动效和宝箱掉落动画的渲染性能\n在高并发送礼场景下保持流畅的动画效果\n性能监控显示优化后全程保持最佳帧率\n我的简历 - 4","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":4,"lines":{"from":36,"to":47}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["473559e7-5411-4fc6-a0f9-b035366c7037",{"pageContent":"\u0000 教育\n⭐ 技术成果：\n封装接口回调数据类型定义，提供完善的 TypeScript 类型提示\n模块化重构重复代码，提升可维护性\n修复 XSS 安全隐患，完善网络层架构\n建立统一的性能监控标准，实现动画性能从 40fps 提升到稳定 60fps\n1.\n2.\n3.\n4.\n2019\n2019.12-\n2020.3\n体态专家IPad、Andriod Pad - flutter开发\n⭐ 项目介绍：体态专家是一套基于人工智能的体态评估系统。该体态评估系统无需\n手动瞄点划线，通过机器视觉技术自动识别身体关键点，模拟人体⻣骼机构并分析\n肌肉的状态，无需拍摄X光片就可以快速预测身体健康的十余项⻛险，最终给出体\n态评分与建议。\n⭐ 技术栈：使用了近期比较火的移动端跨平台方案——flutter，状态管理使用了官\n方推荐的 scope_model。难点在于体态的描点系统，将后端的关键点渲染完毕后，\n前端可进行微调。点击激活关键点保持 canvas 中心，缩放以及移动背景图，再次\n点击确定关键点移动后的位置，类似地图 app 的定位。\n⭐ 主要收获：最满意的app项目，对canvas处理有了比较大的突破，在测试以及\n产品经理的帮助下，将产品一步步的完善，细节处理的也比较到位，对flutter的技\n术栈有了进一步的突破\n2018\n2018.11-2019.5\n体态检测小程序 - React 小程序开发 \n⭐ 项目介绍：公司的核心产品，曾被 keep 抄袭。通过拍摄正面以及侧面两张照片\n即可检测出你的各项体态指标，例如高低肩，头前倾等。\n⭐ 技术栈：使用了 Taro 框架，状态管理使用 Redux，语言使用 TypeScript。由\n于后端使用 grpc 框架，可生成前端可使用的 class 类的 ts 文件，前端发起请求时\n继承此 class 类，遵循接口定义的属性类型，减少了前后端沟通成本以及错误率。\n难点在于体态报告的数据展示，数据结构的处理，包括了姿态融合算法以及⻆度的\n计算，canvas 点，线的绘画等。\n⭐ 主要收获：\n对业务逻辑的强化锻炼，对模块进行的封装，面向对象的编程思想\n对状态管理中状态树的构建等吗强化对 canvas 的各项操作\n首次接触了算法，虽说大部分是借鉴。对复杂的数据的处理，对冗杂的代码进\n行模块化的剖析等。\n1.\n2.\n3.","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":5,"lines":{"from":1,"to":43}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["584bc9e4-b160-4fc1-9452-fbaf0dddf69d",{"pageContent":"难点在于体态报告的数据展示，数据结构的处理，包括了姿态融合算法以及⻆度的\n计算，canvas 点，线的绘画等。\n⭐ 主要收获：\n对业务逻辑的强化锻炼，对模块进行的封装，面向对象的编程思想\n对状态管理中状态树的构建等吗强化对 canvas 的各项操作\n首次接触了算法，虽说大部分是借鉴。对复杂的数据的处理，对冗杂的代码进\n行模块化的剖析等。\n1.\n2.\n3.\n2014-2018电子科技大学中山学院\n通信工程\n我的简历 - 5","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":5,"lines":{"from":34,"to":46}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["94237d46-af6d-474b-acab-383d95073e2c",{"pageContent":"\u0000 个人\n校学生会\n2014—2016学年参加了电子科技大学中山学院校学生会，担任学术部部员 \n河源学子联谊会\n2016—2017学年参加了电子科技大学中山学院河源学子联谊会，担任会⻓ \n孟老师项目组\n2016—2018参加了电子科技大学中山学院孟庆元老师项目组，担任成员，后期担\n任班⻓\n自学能力\n从大二末开始自学前端，加入学院老师项目组做一些全栈项目，毕业后技术栈⻜速成\n⻓，目前能独自承包网站，h5，各类小程序，Andriod app及IOS app的开发。\n工作热情\n喜欢编程，工作踏实，在自己喜欢的氛围下不觉得工作是件应该抱怨的事；态度认真，\n在沟通中有分歧时从来都是选择最优解，不会为了避免增加工作量而选择凑合，融洽的\n团队配合。\n学习热情\n喜欢探索新事物、新技术，喜欢挑战，有好奇心。每年对自己有特定的目标及要求。\n责任心\n对待自己的作品就像自己的孩子一样，认真、细节，注重用户体验\n我的简历 - 6","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739519336626.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":6,"lines":{"from":1,"to":20}},"filename":"吴少航的简历_1739519336626.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T07:48:56.929Z","mimeType":"application/pdf"}}],["83a986cd-4fb3-49c6-bde2-bb4d91b73e98",{"pageContent":"卖家一：真实性申诉，需要poa+发票，但是还是可以提交其他辅助资料的，亚马逊现在\n怀疑的是你是不是在售假，是不是品牌方或者授权方，所以要提交的资料\n1、链接的品牌证书或者品牌授权书\n2、过去时间开具的发票，没有的话补开发票，在发票右下角的备注栏里填上发票补开\n时间\n3、采购订单截图，或者采购合同（盖采购方和销售方的章），送货单\n4、产品带品牌的六面图和包装图\n5、供应商网址\n发票：最好是养成每隔三个月开发票的习惯，现在很多审核申诉都需要增值税发票，要\n是之前没开过发票，开票日期也可以是当天的，在发票右下角这个位置备注上发票补开\n时间，需要在国家税务总局全国增值税发票查验平台真是可查的\n1、购买方信息要填完整，要包括购买方名称，地址，要填跟后台注册信息一致的对应\n中文信息后台手机号打不通写一个自己的能打通的即可，纳税人识别号，开户行及账\n户也要填\n2、商品信息。要包括产品名（listing标题主关键词），规格（可以参考SKU），数量\n（和过去一年内的销量持平，卖的数量很少的话写30到50之间）\n3、供应商信息和购买方信息也一样填完整就行，供应商需要是真实信息，注意要能在\n国家企业信用公示信息系统查询的到的，别是经营状态异常的，手机号要能打得通的\n4、备注补开时间：补开时间在产品上架之后被下架时间之前\n一般第一次不过，后面几次会难很多。但是请不用担心，之前我有一个案例被亚马逊拒\n死-不再回复，我申诉了6-7次一样可以过的\n卖家二:产品真实性投诉（ProductAuthenticityComplaints）一般是由买家匿名发起，并\n且亚马逊会在收到一定的量的买家投诉才会对卖家发出警告。\n申诉解决方案：\n(1)PoA，就是申诉信，老几样了，承认错误，根本原因是啥，采取了什么措施，未来要\n采取什么措施。\n(2)产品采购增值税发票，一年内的，专票普票均可;采购方要和店铺注册的公司一致，\n规格填ASIN，数量要跟近期库存数量差不多，如果不多的话，开个30-50个左右即可。\n切记不能用PI形式发票或者其他不是增值税票的发票。\n(3)品牌授权书（LetterofAuthorization），你或者你的供应商拿到了该品牌的授权。这个","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/亚马逊商品真实性申诉方法及实现步骤(1)_1739519435813.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.7","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"","Author":"admin","Subject":"","Keywords":"","Creator":"WPS 文字","Producer":"","CreationDate":"D:20230803083837+00'38'","ModDate":"D:20230803083837+00'38'","Trapped":{"name":"False"}},"metadata":null,"totalPages":3},"loc":{"pageNumber":1,"lines":{"from":1,"to":30}},"filename":"亚马逊商品真实性申诉方法及实现步骤(1)_1739519435813.pdf","originalFilename":"亚马逊商品真实性申诉方法及实现步骤(1).pdf","uploadedAt":"2025-02-14T07:50:35.895Z","mimeType":"application/pdf"}}],["9392608c-5aac-4ac9-86c9-90accadb61bd",{"pageContent":"不能缺少，因为亚马逊要看到这个才能证明你们以后不会再犯类似的错误了。如果这个\n拿不到的话，大概率申诉不回来---以上1-3必须，缺一不可。其余的采购合同等可以准\n备，但不必要，对申诉没啥帮助。买家信息，供应商信息，商品规格描述在增值税票上\n是有体现的不用另外准备\n1、统计ASIN在过去365天的出单量，发票上的数量必须大于等于这个数量。\n2、发票：先开开一个真的发票，注意发票的购买方信息对应后台店铺信息，发票的销\n售方对应供应商的信息。发票数量至少要2张以上，考虑到实际操作的方便程度和可信\n性，3张最合适;电子发票不行，需要重新开纸质发票\n3、供应商信息：姓名，电话，地址，网站可以写真正的供应商，跟供应商打个招呼就\n行，告诉对方应对话术就好，平台一般是不会去调查的。如果还是不放心，可以把电话\n改成自己的，随机应变就行。\n卖家三：\n1、主要是亚马逊想要了解你是否有真实的在平台上进行商品销售这一行为，了解你的\n商品是否是通过正规渠道来的，在亚马逊所有要求你提供的审核资料里面，采购发票是\n最重要的。一定需要真实的增值税专用发票，同时发票上的采购公司一定要是注册亚马\n逊账号的公司，同时产品的型号必须要和亚马逊后台产品型号或者ASIN或者SKU一致，\n同时需要达到足够多的采购金额，这一点亚马逊在邮件里面会说到。只要发票和其他材\n料没有什么问题，申诉的难度都不会很大\n一般来说，亚马逊快的话，会在48小时内给你回复，但是如果过了一周还是没有任何\n回复或者邮件给你的话，你需要再发邮件给到亚马逊再次申诉。再次申诉的时候，不要\n过于催促，而是重新组织一下之前的申诉信，提醒之前给亚马逊发过邮件了，希望能够\n尽快处理，否则卖家的损失很大，同时可以告诉亚马逊，根据邮件里面我们提出的措施，\n我们已经开始着手做了，怎么做的等等。产品真实性审核也就是我们平常所知的售假投\n诉即不真实性投诉。真实性审核是一类比较严重的违规行为\n如果申诉不成功，账户余额和FBA库存都会被冻结处理。这对于卖家来说，损失极为惨\n重。真实性审核的申诉难度相对来说比较大，因为真实性审核主要就是审核资料。当遇\n到真实性审核时，需要向亚马逊提供以下资料：1.供应商在过去365天内开具的发票、\n收据、合同、配送订单或者授权书的复印件，并且文件中显示的商品数量应当与其实际","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/亚马逊商品真实性申诉方法及实现步骤(1)_1739519435813.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.7","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"","Author":"admin","Subject":"","Keywords":"","Creator":"WPS 文字","Producer":"","CreationDate":"D:20230803083837+00'38'","ModDate":"D:20230803083837+00'38'","Trapped":{"name":"False"}},"metadata":null,"totalPages":3},"loc":{"pageNumber":2,"lines":{"from":1,"to":28}},"filename":"亚马逊商品真实性申诉方法及实现步骤(1)_1739519435813.pdf","originalFilename":"亚马逊商品真实性申诉方法及实现步骤(1).pdf","uploadedAt":"2025-02-14T07:50:35.895Z","mimeType":"application/pdf"}}],["0471f3fa-3b59-42c8-bf09-46bff0d566af",{"pageContent":"诉即不真实性投诉。真实性审核是一类比较严重的违规行为\n如果申诉不成功，账户余额和FBA库存都会被冻结处理。这对于卖家来说，损失极为惨\n重。真实性审核的申诉难度相对来说比较大，因为真实性审核主要就是审核资料。当遇\n到真实性审核时，需要向亚马逊提供以下资料：1.供应商在过去365天内开具的发票、\n收据、合同、配送订单或者授权书的复印件，并且文件中显示的商品数量应当与其实际\n库存相符合。注意：如果你的供应商是中国大陆的公司，那么发票则必须是增值税发票，\n收据、合同的通过率一般很低。千万不要抱着投机取巧的心理使用所谓的假发票，亚马\n逊有完善的系统会去查验发票的真实性。如果亚马逊检测到假发票，一旦发现，永久封\n号\n2.如果不是品牌所有者，需要提供授权书以及可证明有效供应链的全套文件（包括授权\n书）注意：如果是个人注册商标，填写个人信息即可，如果是公司注册商标，则需要填\n写公司信息，加盖公章。\n3.如果是品牌所有者，需要提供品牌注册证书、营业执照或个人身份证的复印件。","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/亚马逊商品真实性申诉方法及实现步骤(1)_1739519435813.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.7","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"","Author":"admin","Subject":"","Keywords":"","Creator":"WPS 文字","Producer":"","CreationDate":"D:20230803083837+00'38'","ModDate":"D:20230803083837+00'38'","Trapped":{"name":"False"}},"metadata":null,"totalPages":3},"loc":{"pageNumber":2,"lines":{"from":24,"to":36}},"filename":"亚马逊商品真实性申诉方法及实现步骤(1)_1739519435813.pdf","originalFilename":"亚马逊商品真实性申诉方法及实现步骤(1).pdf","uploadedAt":"2025-02-14T07:50:35.895Z","mimeType":"application/pdf"}}],["2133038d-2055-40b7-bb26-6ebe5ccd87f4",{"pageContent":"4.供应商的联系信息，包括：名称、电话号码、地址、电子邮件网址和网站。以上，\n这些证明资料除了要确保真实性之外，完整性也相当重要。也就是说，当你遇到真实性\n审核时，以上所需资料既要真实，更要缺一不可。如果你有账户被冻结之前开的发票以\n及完整的授权链条，再附上一封详细的申诉信。通过率还是相对较高的。然而实际上，\n大多数会因为发票补开，以及国内供应商相关信息以及资质不符合亚马逊审核的标注而\n申诉失败。更有因为提供虚假发票而造成永久封号的例子存在。所以建议各位一定要严\n格遵守亚马逊制定的规则，避免不必要的风险，努力优化自身实力，提供质量优秀，价\n格过硬的产品，持续向世界输出中国力量。\n5、一般第一次不过，后面几次会难很多。但是请不用担心，之前我有一个案例被亚马\n逊拒死-不再回复，我申诉了6-7次一样可以过的\n卖家四：有几个东西需要确认\n1.产品是否侵权，外观或者专利侵权，跟卖别人这种低级行为\n2.产品是否Copy抄袭别人的，但是不侵权，别人举报不了你侵权，就搞你\n3.产品质量是否过硬，自己选的产品，应该给的出来答案，产品本身有问题，就不要怨\n天尤人了\n选了3类的产品，谁都救不了，亚马逊不是那个野蛮生长的时代了，选品不用心，后面\n很难搞","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/亚马逊商品真实性申诉方法及实现步骤(1)_1739519435813.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.7","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"","Author":"admin","Subject":"","Keywords":"","Creator":"WPS 文字","Producer":"","CreationDate":"D:20230803083837+00'38'","ModDate":"D:20230803083837+00'38'","Trapped":{"name":"False"}},"metadata":null,"totalPages":3},"loc":{"pageNumber":3,"lines":{"from":1,"to":17}},"filename":"亚马逊商品真实性申诉方法及实现步骤(1)_1739519435813.pdf","originalFilename":"亚马逊商品真实性申诉方法及实现步骤(1).pdf","uploadedAt":"2025-02-14T07:50:35.895Z","mimeType":"application/pdf"}}],["6beb405f-9736-4f71-a781-9e6d5cd4801f",{"pageContent":"卖家您好，北美站后台的税务调查非常简单。 \n点开税务调查开始： \n第一个界面选择 “业务” “否” \n \n纳税身份信息填写的组织名称为公司全名，拼音填写。 \n选择正确的国家及地区（中国香港卖家请在组织所在国家选择中国香港）。 \n \n邮寄地址：或输入您首选用于与亚马逊进行进一步通信的地址。","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/亚马逊北美站点税务调查填写(1)_1739519439125.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.5","IsAcroFormPresent":false,"IsXFAPresent":false,"Author":"Dong, Victor","Creator":"Microsoft® Word 2016","Producer":"Microsoft® Word 2016","CreationDate":"D:20200103121554+08'00'","ModDate":"D:20200103121554+08'00'"},"metadata":null,"totalPages":4},"loc":{"pageNumber":1,"lines":{"from":1,"to":8}},"filename":"亚马逊北美站点税务调查填写(1)_1739519439125.pdf","originalFilename":"亚马逊北美站点税务调查填写(1).pdf","uploadedAt":"2025-02-14T07:50:39.164Z","mimeType":"application/pdf"}}],["e73d1f55-ddd5-4ee5-9806-5413b1d9bb01",{"pageContent":"此处签名卖家填写法人姓名的拼音 \n名 +  姓 （如张三，填写 San Zhang）","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/亚马逊北美站点税务调查填写(1)_1739519439125.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.5","IsAcroFormPresent":false,"IsXFAPresent":false,"Author":"Dong, Victor","Creator":"Microsoft® Word 2016","Producer":"Microsoft® Word 2016","CreationDate":"D:20200103121554+08'00'","ModDate":"D:20200103121554+08'00'"},"metadata":null,"totalPages":4},"loc":{"pageNumber":2,"lines":{"from":2,"to":3}},"filename":"亚马逊北美站点税务调查填写(1)_1739519439125.pdf","originalFilename":"亚马逊北美站点税务调查填写(1).pdf","uploadedAt":"2025-02-14T07:50:39.164Z","mimeType":"application/pdf"}}],["1c887b8e-685b-4d7d-8da6-ec72a7790b63",{"pageContent":"最后点击提交表格即可。 \n税务调查结束。","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/亚马逊北美站点税务调查填写(1)_1739519439125.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.5","IsAcroFormPresent":false,"IsXFAPresent":false,"Author":"Dong, Victor","Creator":"Microsoft® Word 2016","Producer":"Microsoft® Word 2016","CreationDate":"D:20200103121554+08'00'","ModDate":"D:20200103121554+08'00'"},"metadata":null,"totalPages":4},"loc":{"pageNumber":4,"lines":{"from":2,"to":3}},"filename":"亚马逊北美站点税务调查填写(1)_1739519439125.pdf","originalFilename":"亚马逊北美站点税务调查填写(1).pdf","uploadedAt":"2025-02-14T07:50:39.164Z","mimeType":"application/pdf"}}],["9ceae20a-d4f4-4ae1-8cb2-40c48f8f5f9c",{"pageContent":"\u0000 工作经历\n我的简历\n28岁，前端开发，6年经验\n擅⻓WEB • H5 • APP • 小程序 • 客户端的开发\n逻辑思维能力与同理心强，擅⻓人与人之间沟通协作\n15876092583\n\nw583175694\n\n583175694@qq.com\n✉\n2024\n2022.8-至今\n2022\n2021.11-2022.7\n微众 - 大前端工程师\n担任前端工程师，负责微众银行企业金融APP的开发\n负责部⻔内部AI大模型应用的开发\n腾讯 - 大前端工程师\n担任前端工程师，负责拳头游戏 Valorant 登录器 Electron 客户端的开发\n掌上英雄联盟电竞经理手游社区项目 React Native 的开发\n2020\n2020.7-2021.11\n深圳市果酱时代科技有限公司 - 前端工程师\n担任前端工程师，负责直播平台的功能迭代、礼物动效性能优化、历史遗留问题\n的修复\n2018\n2018.8-2020.7\n深圳创感科技有限公司 - 大前端工程师\n 担任大前端工程师，负责网⻚、H5、小程序、Flutter APP开发\n我的简历 - 1","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":1,"lines":{"from":1,"to":31}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["d52f2ee5-526c-4b80-8ea9-f693fac2058c",{"pageContent":"\u0000 技能特⻓\n擅⻓ \nHTML\n，\nCSS3\n，\nW3C\n 标准和语义化标签，熟练实现各种动效，布局   \n擅⻓ \nES5\n，\nES6\n，\nTypeScript\n \n擅⻓ \nReact\n、\nReact Hooks\n及其全家桶，\nRedux\n 状态机\n擅⻓ \nVue2\n、\nVue3\n 及其全家桶  \n擅⻓ \nReact Native\n、\nFlutter\n 跨端开发，能够独立完成 \niOS\n，\nAndroid\n 的开发  \n擅⻓\nLangchain\n、\nprompt turning\n等AI应用开发基础\n熟悉 \nElectron\n 客户端的跨端开发，以及\nvscode\n插件开发\n熟悉 \nNodeJS\n，能够使用 \nNestJS\n 完成数据中台的开发\n熟悉 \nHTTP\n/\nHTTPS\n/\nQUIC\n 等网络协议基本原理\n熟练使用 \ngit\n 代码管理工具，会用 \ngit\n 可视化工具解决代码冲突\n\u0000 项目经历\n2024\n2022.8-至今\n微众银行 - 微众银行企业金融APP - \nReact  Native\n开发 - \nVue3\n开\n发\n⭐ 项目介绍：微众银行是领先的数字银行，专注为中小微企业和普罗大众提供更为\n优质、便捷的金融服务。包含贷款、贴现、保险、理财、账户、微创投\n⭐ 技术栈：\n业务层：React Native，React Hook，Vue3，Vite，TypeScript；\n能力层：Android Native，iOS Native，跨端能力建设，SDK建设，监控建\n设；\n应用安全层：国密SSL SM4、SM2，交易密码验证，FIDO生物识别，人脸认\n证、在线视频等。\n⭐ 主要职能：\n业务发展与客户服务：负责企业开户、企业信息变更、保险产品、存款服务、\n专利AI、微创投资、聚合支付和薪资发放等关键业务的开发与流程优化，以及\n支付安全相关的设计。\n安全体系建设：设计并实施了全面的登录安全体系，包括报文加密、手机号绑\n定、手势密码、面部识别、指纹识别、一次性密码（OTP）、面部认证和在线视\n频验证等多重安全措施，以增强账户安全性和用户信任。\n1.\n2.\n3.\n1.\n2.\n技术项目管理：3.\n我的简历 - 2","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":2,"lines":{"from":1,"to":94}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["3c5f2d35-d453-4462-8599-8866b8628f4c",{"pageContent":"负责H5项目工程化建设，采用pnpm monorepo架构，成功整合和改造了\n包括理财、保险、票据等在内的十多个H5应用。管理项目依赖，优化公共\n代码库，实施持续集成/持续部署（CI/CD）流程，确保版本控制和软件发\n布流程的高效与稳定。\n参与企业金融APP跨端能力建设，设计并实现基于JS-SDK架构的跨端解\n决方案，提供包括用户信息获取、支付、生物识别等30+原生能力调用。\n构建了基于appId+appSecret的鉴权机制和code置换登录态的双重认证\n体系，实现H5与Native间安全可信通信。通过Webview拦截器结合\nMD5+盐值校验的离线包加载方案使首屏加载提速50%，并基于域名白名\n单+jsTicket的动态校验确保接口调用安全。完善SDK文档和标准化建\n设，简化业务方接入流程，目前已接入数十个业务。\na.\nb.\n2024\n2023.9-至今\n微众银行 - AI大模型应用体系建设\n⭐ 项目介绍：在当前的行业趋势下，我们致力于通过采用先进的人工智能技术，以\n创新的方式实现成本优化和效率提升。目前的产品有VSCode编辑器AI插件，前\n端RAG与知识库平台，管理台代码生成平台。\n⭐ 技术栈：Langchain，codellama，deepseek，RAG，Chroma，Prompt \ntune，VSCode SDK，NestJS\n⭐ 主要职能：\nAI大模型应用体系建设负责人：负责部⻔内人工智能大模型的应用体系构建，\n推动AI技术在业务流程中的深度融合与创新应用。\nVSCode AI插件开发：开发VSCode编辑器AI插件，整合Codellama 34B和\nDeepSeek 7B模型，实现代码生成、智能补全、代码翻译、智能问答等功能。\n插件已实现代码补全采纳20,000+次，采纳率达12%，智能问答3,000+次，\n显著提升团队编码效率近30%。\n前端RAG与知识库平台建设：运用Langchain、Embedding模型和向量数据\n库技术，结合本地部署的ChatGLM3模型，构建前端团队知识库平台，优化团\n队资料检索流程。\n管理台代码生成平台开发：利用Codellama 34B模型和prompt tuning技术，\n开发基于自然语言的Vue2 + CompositionAPI + ElementUI管理台代码生成平","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":3,"lines":{"from":1,"to":33}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["5697c04b-cc69-429d-ba70-877fc03f1b39",{"pageContent":"前端RAG与知识库平台建设：运用Langchain、Embedding模型和向量数据\n库技术，结合本地部署的ChatGLM3模型，构建前端团队知识库平台，优化团\n队资料检索流程。\n管理台代码生成平台开发：利用Codellama 34B模型和prompt tuning技术，\n开发基于自然语言的Vue2 + CompositionAPI + ElementUI管理台代码生成平\n台。集成vue-live实现代码实时预览功能，进一步提升开发效率和用户体验。\n1.\n2.\n3.\n4.\n2022\n2021.11-2022.8\n腾讯IEG - Valorant 客户端 - Electron开发\n⭐ 项目介绍：拳头游戏 Valorant 在国外已经上线且有不错的关注度，Valorant 计\n划在 2022 年下半年引入国内，因此需要做一个游戏的启动器，功能点包括游戏的\n登录、游戏更新、启动器的更新、游戏与启动器数据的共享、用户登录态的校验等\n等\n⭐ 技术栈：客户端采用 Electron 跨端技术实现客户端底层能力，前端使用 Vue3 \n+ Vite + tailwindcss 作为基础业务的搭建，中台基于 node + nestjs + serverless \n对接多项第三方业务平台，提供拳头公司游戏统一协调服务\n我的简历 - 3","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":3,"lines":{"from":29,"to":49}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["3aeb4ee1-e9dd-41f6-9fdb-7e0cccbe56dd",{"pageContent":"⭐ 主要收获：\n掌握 Electron 客户端的研发，以及主进程、渲染进程之间的IPC通信协议，基\n于 node 对 window 客户端底层能力的协调处理\n参与中台的基础架构以及技术选型，基于 node 对第三方服务进行统一规范，以\n及提供拳头公司服务对接\n参与制定拳头公司的对接安全规范，实现业务方与平台方的信息安全交互\n1.\n2.\n3.\n2021\n2021.11-2022.8\n腾讯IEG - 掌上英雄联盟APP电竞经理社区 - React Native开发\n⭐ 项目介绍：腾讯计划在 2022 年年中上线“电竞经理手游”，掌上英雄联盟作为\n拳头游戏的社区平台，将新增“电竞经理”社区模块。功能点包括游戏的资讯，阵容\n的推荐、用户个人资料显示、战绩查询等等\n⭐ 技术栈：采用移动端跨平台方案 React Native + React Hooks + fower 作为应\n用的框架，使用 react-native-echarts-pro 作为图表功能的处理，采用 React \nNative 原生动画对用户体验的优化\n⭐ 主要收获：\n掌握 React Native 的研发及其实现原理，提供多端适配的解决方案\n掌握 React Hooks API 的使用，对通用组件进行统一抽象处理\n独立调研并最终推广实现 fower 技术解决方案， 解决 react native 样式体积\n大、复杂度高的问题，极大提高了前端项目组的开发效率\n参与掌上英雄联盟团队的开发协作\n1.\n2.\n3.\n4.\n2020\n2020.7-2021.11\n星光直播平台 - Web/小程序开发\n⭐ 项目介绍：\n星光直播是一个综合性视频社交平台,包含直播和短视频两大核心功能。我主要负责:\n基于 Taro + TypeScript 开发短视频模块,实现类抖音的视频浏览体验\n使用原生 JavaScript + PHP 开发直播模块,通过 Bodymovin 实现礼物动效渲染\n⭐ 技术难点与解决方案：\n1.\n2.\n短视频模块性能优化1.\n使用 Redux 管理状态，避免滑动切换时的卡顿\n优化视频切换和评论抽屉等动画，使性能监控保持在 60 帧\n双层 Swiper 嵌套方案实现流畅的视频切换效果\n直播模块动效优化2.\n优化礼物动效和宝箱掉落动画的渲染性能\n在高并发送礼场景下保持流畅的动画效果","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":4,"lines":{"from":1,"to":45}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["3694247a-6ea8-40ba-97ea-00c528df108b",{"pageContent":"⭐ 技术难点与解决方案：\n1.\n2.\n短视频模块性能优化1.\n使用 Redux 管理状态，避免滑动切换时的卡顿\n优化视频切换和评论抽屉等动画，使性能监控保持在 60 帧\n双层 Swiper 嵌套方案实现流畅的视频切换效果\n直播模块动效优化2.\n优化礼物动效和宝箱掉落动画的渲染性能\n在高并发送礼场景下保持流畅的动画效果\n性能监控显示优化后全程保持最佳帧率\n我的简历 - 4","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":4,"lines":{"from":36,"to":47}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["e252efcb-a735-464e-8a34-06748bf9f186",{"pageContent":"\u0000 教育\n⭐ 技术成果：\n封装接口回调数据类型定义，提供完善的 TypeScript 类型提示\n模块化重构重复代码，提升可维护性\n修复 XSS 安全隐患，完善网络层架构\n建立统一的性能监控标准，实现动画性能从 40fps 提升到稳定 60fps\n1.\n2.\n3.\n4.\n2019\n2019.12-\n2020.3\n体态专家IPad、Andriod Pad - flutter开发\n⭐ 项目介绍：体态专家是一套基于人工智能的体态评估系统。该体态评估系统无需\n手动瞄点划线，通过机器视觉技术自动识别身体关键点，模拟人体⻣骼机构并分析\n肌肉的状态，无需拍摄X光片就可以快速预测身体健康的十余项⻛险，最终给出体\n态评分与建议。\n⭐ 技术栈：使用了近期比较火的移动端跨平台方案——flutter，状态管理使用了官\n方推荐的 scope_model。难点在于体态的描点系统，将后端的关键点渲染完毕后，\n前端可进行微调。点击激活关键点保持 canvas 中心，缩放以及移动背景图，再次\n点击确定关键点移动后的位置，类似地图 app 的定位。\n⭐ 主要收获：最满意的app项目，对canvas处理有了比较大的突破，在测试以及\n产品经理的帮助下，将产品一步步的完善，细节处理的也比较到位，对flutter的技\n术栈有了进一步的突破\n2018\n2018.11-2019.5\n体态检测小程序 - React 小程序开发 \n⭐ 项目介绍：公司的核心产品，曾被 keep 抄袭。通过拍摄正面以及侧面两张照片\n即可检测出你的各项体态指标，例如高低肩，头前倾等。\n⭐ 技术栈：使用了 Taro 框架，状态管理使用 Redux，语言使用 TypeScript。由\n于后端使用 grpc 框架，可生成前端可使用的 class 类的 ts 文件，前端发起请求时\n继承此 class 类，遵循接口定义的属性类型，减少了前后端沟通成本以及错误率。\n难点在于体态报告的数据展示，数据结构的处理，包括了姿态融合算法以及⻆度的\n计算，canvas 点，线的绘画等。\n⭐ 主要收获：\n对业务逻辑的强化锻炼，对模块进行的封装，面向对象的编程思想\n对状态管理中状态树的构建等吗强化对 canvas 的各项操作\n首次接触了算法，虽说大部分是借鉴。对复杂的数据的处理，对冗杂的代码进\n行模块化的剖析等。\n1.\n2.\n3.","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":5,"lines":{"from":1,"to":43}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["9952d538-261e-44ca-a83a-bcb9a5527841",{"pageContent":"难点在于体态报告的数据展示，数据结构的处理，包括了姿态融合算法以及⻆度的\n计算，canvas 点，线的绘画等。\n⭐ 主要收获：\n对业务逻辑的强化锻炼，对模块进行的封装，面向对象的编程思想\n对状态管理中状态树的构建等吗强化对 canvas 的各项操作\n首次接触了算法，虽说大部分是借鉴。对复杂的数据的处理，对冗杂的代码进\n行模块化的剖析等。\n1.\n2.\n3.\n2014-2018电子科技大学中山学院\n通信工程\n我的简历 - 5","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":5,"lines":{"from":34,"to":46}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["780cb9a4-d2fb-4476-80a3-ab87b8984771",{"pageContent":"\u0000 个人\n校学生会\n2014—2016学年参加了电子科技大学中山学院校学生会，担任学术部部员 \n河源学子联谊会\n2016—2017学年参加了电子科技大学中山学院河源学子联谊会，担任会⻓ \n孟老师项目组\n2016—2018参加了电子科技大学中山学院孟庆元老师项目组，担任成员，后期担\n任班⻓\n自学能力\n从大二末开始自学前端，加入学院老师项目组做一些全栈项目，毕业后技术栈⻜速成\n⻓，目前能独自承包网站，h5，各类小程序，Andriod app及IOS app的开发。\n工作热情\n喜欢编程，工作踏实，在自己喜欢的氛围下不觉得工作是件应该抱怨的事；态度认真，\n在沟通中有分歧时从来都是选择最优解，不会为了避免增加工作量而选择凑合，融洽的\n团队配合。\n学习热情\n喜欢探索新事物、新技术，喜欢挑战，有好奇心。每年对自己有特定的目标及要求。\n责任心\n对待自己的作品就像自己的孩子一样，认真、细节，注重用户体验\n我的简历 - 6","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/吴少航的简历_1739521699404.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.4","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"我的简历","Creator":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/131.0.0.0 Safari/537.36","Producer":"Skia/PDF m131","CreationDate":"D:20250212160830+00'00'","ModDate":"D:20250212160830+00'00'"},"metadata":null,"totalPages":6},"loc":{"pageNumber":6,"lines":{"from":1,"to":20}},"filename":"吴少航的简历_1739521699404.pdf","originalFilename":"吴少航的简历.pdf","uploadedAt":"2025-02-14T08:28:19.544Z","mimeType":"application/pdf"}}],["5f14c16e-6f73-4631-b28d-dc31f7f567d7",{"pageContent":"Country of origin:\nDate:\nNovember 28,2023\nModel:\nProduction batch number:\nProduction Date:\nManufacturer:\nEC REP:\nWARNING:\nTO AVOID DANGER OF SUFFOCATION,KEEP THIS PLASTIC BAGAWAY FROM\nBABIES AND CHILDREN.DO NOT USE THIS BAG IN CRIBS,BEDS CARRIAGES \nOR PLAY PENS.THIS BAG IS NOT A TOY\nMade in china\nAddress:\nUK REP:\nWARNING\nWARNING:\nCHOKING HAZARD‑Small parts\nNot for children under 3 yrs.\n6+","metadata":{"source":"/Users/wushaohang/code/other/hello-deepseek/server/uploads/欧洲GPSR标签示例_1739522321721.pdf","pdf":{"version":"1.10.100","info":{"PDFFormatVersion":"1.6","IsAcroFormPresent":false,"IsXFAPresent":false,"Title":"欧洲GPSR标签参考","CreationDate":"D:20240815141846+08'00'","ModDate":"D:20240830165959+08'00'","Trapped":{"name":"False"}},"metadata":{"_metadata":{"dc:format":"application/pdf","dc:title":"欧洲GPSR标签参考","xmp:createdate":"2024-08-15T14:18:46+08:00","xmp:modifydate":"2024-08-30T16:59:59+08:00","xmp:metadatadate":"2024-08-30T16:59:59+08:00","xmpmm:documentid":"uuid:61ba4069-3eb9-324f-a38b-76027a2da49c","xmpmm:instanceid":"uuid:049388d4-1fa6-2349-877a-8c863aabf839","xmpmm:renditionclass":"default","xmpmm:versionid":"1","pdfxid:gts_pdfxversion":"PDF/X-4","pdf:trapped":"False","pdfaextension:schemas":"http://ns.adobe.com/pdf/1.3/pdfAdobe PDF SchemainternalA name object indicating whether the document has been modified to include trapping informationTrappedTexthttp://ns.adobe.com/xap/1.0/mm/xmpMMXMP Media Management SchemainternalUUID based identifier for specific incarnation of a documentInstanceIDURIinternalThe common identifier for all v